# Copy to .env and fill in. Every value is optional; sensible defaults apply.

# ───────────── LLM backend (OpenAI-compatible) ─────────────
# Point at ANY OpenAI-compatible endpoint and give it the matching key.
# Examples:
#   OpenRouter:           https://openrouter.ai/api/v1
#   OpenAI:               https://api.openai.com/v1
#   Local LiteLLM proxy:  http://host.docker.internal:4000/v1   (proxy on the host)
SWARM_LLM_BASE_URL=https://openrouter.ai/api/v1
SWARM_LLM_API_KEY=sk-replace-me
SWARM_DEFAULT_MODEL=openai/gpt-4o-mini
# Shown in the model dropdown if the backend can't be queried (comma-separated):
SWARM_FALLBACK_MODELS=openai/gpt-4o-mini

# ───────────── Server ─────────────
# SWARM_HOST=0.0.0.0          # set by Docker; keep 127.0.0.1 for local-only
# SWARM_PORT=8000
# SWARM_API_KEY=              # require this key on EVERY endpoint + the WebSocket — SET IT if you expose the port
# SWARM_DATA_DIR=/data        # writable state dir (set by Docker to the volume)
# SWARM_SWEEP_INTERVAL=10
# SWARM_LOG_FILE=             # also write logs to this path (rotating 10MB × 5); stdout is always on

# ───────────── Browser handover ─────────────
# How a human completes an interactive login the agent is blocked on:
#   embedded (default) — drive the headless browser from a panel in the dashboard
#                        (works on a display-less VPS)
#   window             — pop a real Chrome window on the SERVER's desktop (only if
#                        the server has a display, e.g. your own machine)
# SWARM_TAKEOVER_MODE=embedded

# ───────────── Hermes ─────────────
# Only needed if Hermes is NOT pip-installed and you run from a source checkout:
# HERMES_AGENT_PATH=/path/to/hermes-agent
